# SOUL — Environment Variables
# Copy to .env and fill in your values
# Never commit .env to version control

# ── LLM — required ───────────────────────────────────────────────────────────
# Primary key for chat inference (llama-3.3-70b and fallback models)
# Get a free key at: https://console.groq.com
GROQ_API_KEY=paste_your_key_here

# ── LLM — rate limit rotation (optional) ─────────────────────────────────────
# Add up to two extra keys — SOUL rotates through them automatically
# GROQ_API_KEY_2=paste_second_key_here
# GROQ_API_KEY_3=paste_third_key_here

# ── Vision — separate key pool (optional) ────────────────────────────────────
# Used for screen-reading calls (llama-4-scout-17b-16e-instruct)
# Falls back to GROQ_API_KEY pool if not set
# GROQ_VISION_KEY=paste_vision_key_here
# GROQ_VISION_KEY_2=paste_second_vision_key_here

# ── Voice — v2 pipeline (optional) ───────────────────────────────────────────
# Required only if you want Porcupine wake-word detection
# Get a free key at: https://console.picovoice.ai
# PORCUPINE_KEY=paste_your_porcupine_key_here
