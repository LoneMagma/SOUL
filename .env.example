# SOUL — Environment Variables
# Copy to .env and fill in your key(s)

# Primary API key (required)
GROQ_API_KEY=paste_your_key_here

# Optional: add up to 2 more keys for rate limit rotation
# GROQ_API_KEY_2=paste_second_key_here
# GROQ_API_KEY_3=paste_third_key_here

# Get free keys at: https://console.groq.com
